# Django Delivery Service Configuration
# ======================================
# Copy this file to .env and update values for your environment

# Django Core
# -----------
# SECRET_KEY: Криптографический ключ для подписи сессий и cookies.
#             Сгенерируйте уникальный ключ: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here-change-in-production

# DEBUG: Режим отладки. True для разработки, False для production
DEBUG=True

# ALLOWED_HOSTS: Список доменов, через запятую
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
# ---------------------
# USE_POSTGRES: True - PostgreSQL, False - SQLite
USE_POSTGRES=True

DB_NAME=delivery_service
DB_USER=postgres
DB_PASSWORD=postgres_password_change_me
DB_HOST=postgres
DB_PORT=5432

# Application
# -----------
APP_NAME="Delivery Service"
API_VERSION=v1

# Logging
# -------
# LOG_LEVEL: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# LOG_FORMAT: console (читаемый) или json (структурированный)
LOG_FORMAT=console

# Security (Development)
# ----------------------
# Для production установите все в True и настройте HTTPS
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False

# CORS (Cross-Origin Resource Sharing)
# ------------------------------------
# Список доменов, через запятую, с которых разрешены запросы к API
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# File Upload
# -----------
# MAX_UPLOAD_SIZE: Максимальный размер файла в мегабайтах
MAX_UPLOAD_SIZE=10

# ALLOWED_EXTENSIONS: Разрешённые расширения файлов, через запятую
ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.pdf

# Redis Configuration
# -------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
CACHE_TTL=3600

# Celery Configuration
# --------------------
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0